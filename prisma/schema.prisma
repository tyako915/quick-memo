generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Memo {
  id        String   @id @default(cuid())
  title     String   @default("")
  content   String
  roomId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
}
